# ==========================================
# 前端部分 (React + Vite + Node.js)
# ==========================================
# 依赖包
node_modules/

# 编译与打包产物
dist/
dist-ssr/
build/

# 日志文件
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 本地环境变量 (包含 API Key 等敏感信息)
.env
.env.local
.env.*.local

# ==========================================
# 后端部分 (.NET Core / C#)
# ==========================================
# 编译输出目录 (核心排除)
[Bb]in/
[Oo]bj/

# 发布输出目录 (你之前打包生成的那些)
publish/
publish_output/
out/

# 用户特定文件 (VS 本地配置)
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# ==========================================
# 编辑器与 IDE 配置
# ==========================================
# Visual Studio
.vs/

# Visual Studio Code 
# (排除本地配置，但保留共享的扩展推荐)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# Rider / WebStorm (JetBrains)
.idea/

# ==========================================
# 操作系统生成文件
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db